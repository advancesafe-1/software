{
  "name": "advancesafe",
  "version": "1.0.0",
  "description": "AdvanceSafe — Windows desktop safety management system for Indian industrial factories",
  "main": "dist-electron/main.js",
  "author": "Advanced SOS Max",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "dev:renderer": "vite",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "build:installer": "npm run build && electron-builder --win --x64 --config electron-builder.yml",
    "build:installer:publish": "npm run build && electron-builder --win --x64 --config electron-builder.yml --publish always",
    "build:renderer": "vite build",
    "dist": "npm run build:installer",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@pixi/graphics-extras": "^7.4.3",
    "better-sqlite3": "^9.0.0",
    "electron": "^28.0.0",
    "firebase": "^10.0.0",
    "firebase-admin": "^12.0.0",
    "lucide-react": "latest",
    "node-fetch": "^2.7.0",
    "pixi.js": "^7.4.3",
    "puppeteer": "^24.37.5",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "react-window": "^1.8.0",
    "recharts": "^2.0.0",
    "zustand": "^4.0.0",
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "latest",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "latest",
    "tailwindcss": "^3.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
